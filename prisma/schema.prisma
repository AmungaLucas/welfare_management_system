generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// WELFARE SYSTEM DATABASE SCHEMA
// ACK St. Monica Parish - Utawala
// ============================================

// Districts in the church
model District {
  id        Int      @id @default(autoincrement())
  name      String   @unique // BETHLEHEM, SAMARIA, NAZARETH, JERUSALEM, GALILEE, BETHANY, JUDEA, DIASPORA, UNIVERSAL
  isActive  Boolean  @default(true)
  members   Member[]
  createdAt DateTime @default(now())

  @@map("districts")
}

// User accounts (auth) - Admin and Members
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          Role      @default(MEMBER) // ADMIN or MEMBER
  isActive      Boolean   @default(true)
  phone         String?   
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  member        Member?

  @@map("users")
}

enum Role {
  ADMIN
  MEMBER
}

// Welfare members
model Member {
  id                      String          @id @default(cuid())
  userId                  String?         @unique
  churchMembershipNo      String          @unique @map("church_membership_no") 
  welfareNo               Int?            @unique @map("welfare_no")
  firstName                String          @map("first_name") 
  lastName                 String          @map("last_name") 
  otherNames               String?         @map("other_names") 
  phone                   String          
  email                   String?         
  districtId              Int
  district                District        @relation(fields: [districtId], references: [id])
  churchMembershipDate     DateTime?       @map("church_membership_date")
  churchDurationYears      Int?            @map("church_duration_years")
  isNewChurchMember       Boolean         @default(false) @map("is_new_church_member") // <=2 years

  // Family details (for bereavement coverage)
  spouseName              String?         @map("spouse_name") 
  spouseAlive             Boolean?        @default(true) @map("spouse_alive")
  fatherName              String?         @map("father_name") 
  fatherAlive             Boolean?        @default(true) @map("father_alive")
  motherName              String?         @map("mother_name") 
  motherAlive             Boolean?        @default(true) @map("mother_alive")

  // Next of Kin
  nextOfKinName           String?         @map("next_of_kin_name") 
  nextOfKinPhone          String?         @map("next_of_kin_phone") 
  nextOfKinRelationship   String?         @map("next_of_kin_relationship") 

  // Membership status
  status                  MemberStatus    @default(PENDING_APPROVAL)
  joiningFeePaid          Decimal         @default(0) @map("joining_fee_paid") 
  registrationFeePaid     Decimal         @default(0) @map("registration_fee_paid") 
  dateJoinedWelfare       DateTime?       @map("date_joined_welfare")

  // Wallet balance (overpayments held)
  walletBalance           Decimal         @default(0) @map("wallet_balance") 

  // Arrears tracking
  consecutiveArrears      Int             @default(0) @map("consecutive_arrears")
  totalDefaultEvents      Int             @default(0) @map("total_default_events")
  suspendedUntil          DateTime?       @map("suspended_until")
  removedFromRegister     Boolean         @default(false) @map("removed_from_register")
  removalDate             DateTime?       @map("removal_date")

  user                    User?           @relation(fields: [userId], references: [id])
  contributions           Contribution[]
  walletTransactions      WalletTransaction[]
  bereavementCases        BereavementCase[]  @relation("AffectedMember")
  caseContributions       CaseContribution[]
  benefitDisbursements    BenefitDisbursement[]
  children                FamilyChild[]
  annualRenewals          AnnualRenewal[]
  burialAttendees         BurialAttendee[]
  notifications           Notification[]
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([districtId])
  @@index([status])
  @@index([churchMembershipNo])
  @@map("members")
}

enum MemberStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  REMOVED
}

// Family children (for bereavement coverage - children under 25)
model FamilyChild {
  id          String    @id @default(cuid())
  memberId    String    @map("member_id")
  member      Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  fullName    String    @map("full_name") 
  dateOfBirth DateTime? @map("date_of_birth")
  isAlive     Boolean   @default(true) @map("is_alive")
  createdAt   DateTime  @default(now())

  @@map("family_children")
}

// Monthly contributions
model Contribution {
  id              String          @id @default(cuid())
  memberId        String          @map("member_id")
  member          Member          @relation(fields: [memberId], references: [id])
  year            Int
  month           Int             // 1-12
  amount          Decimal         
  paymentMethod   PaymentMethod    @default(MPESA) @map("payment_method")
  mpesaRef        String?         @map("mpesa_ref") 
  transactionRef  String?         @map("transaction_ref") 
  status          ContributionStatus @default(COMPLETED)
  paidDate        DateTime        @default(now()) @map("paid_date")
  recordedBy      String?         @map("recorded_by") 
  notes           String?         
  createdAt       DateTime        @default(now())

  @@unique([memberId, year, month])
  @@index([memberId, year])
  @@map("contributions")
}

enum PaymentMethod {
  MPESA
  CASH
  BANK_TRANSFER
  WALLET
}

enum ContributionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// Wallet transactions (overpayments, auto-deductions, refunds)
model WalletTransaction {
  id              String                @id @default(cuid())
  memberId        String                @map("member_id")
  member          Member                @relation(fields: [memberId], references: [id])
  type            WalletTransactionType
  amount          Decimal               
  balanceBefore   Decimal               @map("balance_before") 
  balanceAfter    Decimal               @map("balance_after") 
  description     String                
  referenceId     String?               @map("reference_id")  // e.g., contribution_id or case_contribution_id
  referenceType   String?               @map("reference_type")  // CONTRIBUTION, CASE_CONTRIBUTION, MONTHLY_DEDUCT, REFUND
  createdAt       DateTime              @default(now())

  @@index([memberId])
  @@map("wallet_transactions")
}

enum WalletTransactionType {
  CREDIT   // overpayment credited
  DEBIT    // auto-deduct for monthly or case
  REFUND   // admin approved refund
}

// Bereavement cases
model BereavementCase {
  id                  String              @id @default(cuid())
  memberId            String              @map("member_id")
  member              Member              @relation("AffectedMember", fields: [memberId], references: [id])
  
  // Deceased details
  deceasedName        String              @map("deceased_name") 
  deceasedRelationship DeceasedRelation    @map("deceased_relationship")
  deceasedAge         Int?                @map("deceased_age")
  dateOfDeath         DateTime?           @map("date_of_death")
  dateOfBurial        DateTime?           @map("date_of_burial")
  burialLocation      String?             @map("burial_location") 
  
  // Contribution tracking
  category            BereavementCategory // determines amount per member
  contributionPerMember Decimal           @default(300) @map("contribution_per_member") 
  totalExpected       Int                 @default(0) @map("total_expected") // active members * contributionPerMember
  totalCollected      Decimal             @default(0) @map("total_collected") 
  
  // Benefit
  benefitAmount       Decimal             @default(0) @map("benefit_amount") 
  benefitStatus       BenefitStatus       @default(PENDING)
  benefitDisbursedDate DateTime?          @map("benefit_disbursed_date")
  benefitDisbursement BenefitDisbursement?
  
  // Coverage checks
  memberEligible      Boolean             @default(true) @map("member_eligible")
  eligibilityNotes    String?             @map("eligibility_notes") 
  waitingPeriodSatisfied Boolean          @default(true) @map("waiting_period_satisfied")
  
  // Case status
  status              CaseStatus          @default(ACTIVE)
  contributionDeadline DateTime?          @map("contribution_deadline")
  loggedBy            String              @map("logged_by") 
  
  caseContributions   CaseContribution[]
  burialAttendees     BurialAttendee[]
  notifications       Notification[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([memberId])
  @@index([status])
  @@map("bereavement_cases")
}

enum DeceasedRelation {
  MEMBER      // the member themselves
  SPOUSE
  CHILD
  PARENT      // member's parent
  SPOUSE_PARENT // spouse's parent
}

enum BereavementCategory {
  NUCLEAR_FAMILY   // Member/Spouse/Child -> Kshs 100,000, Kshs 300/member
  PARENT           // Parent -> Kshs 60,000, Kshs 200/member
}

enum BenefitStatus {
  PENDING
  APPROVED
  DISBURSED
  REJECTED
}

enum CaseStatus {
  ACTIVE
  CONTRIBUTIONS_CLOSED
  COMPLETED
  CANCELLED
}

// Individual member contributions to a bereavement case
model CaseContribution {
  id              String          @id @default(cuid())
  caseId          String          @map("case_id")
  case            BereavementCase @relation(fields: [caseId], references: [id])
  memberId        String          @map("member_id")
  member          Member          @relation(fields: [memberId], references: [id])
  expectedAmount  Decimal         @default(300) @map("expected_amount") 
  paidAmount      Decimal         @default(0) @map("paid_amount") 
  paymentMethod   PaymentMethod    @default(MPESA) @map("payment_method")
  mpesaRef        String?         @map("mpesa_ref") 
  status          CaseContributionStatus @default(PENDING)
  paidDate        DateTime?       @map("paid_date")
  notes           String?         
  createdAt       DateTime        @default(now())

  @@unique([caseId, memberId])
  @@index([caseId])
  @@index([memberId])
  @@map("case_contributions")
}

enum CaseContributionStatus {
  PENDING
  PAID
  EXEMPTED
  DEFAULTED
}

// Burial attendees (admin tracking)
model BurialAttendee {
  id              String          @id @default(cuid())
  caseId          String          @map("case_id")
  case            BereavementCase @relation(fields: [caseId], references: [id])
  memberId        String          @map("member_id")
  member          Member          @relation(fields: [memberId], references: [id])
  role            String?          // e.g., "Representative", "Committee"
  createdAt       DateTime        @default(now())

  @@map("burial_attendees")
}

// Benefit disbursement records
model BenefitDisbursement {
  id              String          @id @default(cuid())
  caseId          String          @unique @map("case_id")
  case            BereavementCase @relation(fields: [caseId], references: [id])
  memberId        String          @map("member_id")
  member          Member          @relation(fields: [memberId], references: [id])
  amount          Decimal         
  disbursementMethod String?       @map("disbursement_method") 
  referenceNo     String?         @map("reference_no") 
  disbursedDate   DateTime        @map("disbursed_date")
  receivedByName  String?         @map("received_by_name") 
  receivedByIdNo  String?         @map("received_by_id_no") 
  notes           String?         
  createdAt       DateTime        @default(now())

  @@map("benefit_disbursements")
}

// Annual membership renewals
model AnnualRenewal {
  id              String          @id @default(cuid())
  memberId        String          @map("member_id")
  member          Member          @relation(fields: [memberId], references: [id])
  year            Int
  amount          Decimal         @default(200) 
  status          RenewalStatus   @default(PENDING)
  dueDate         DateTime        @map("due_date")
  paidDate        DateTime?       @map("paid_date")
  paymentMethod   PaymentMethod?  @map("payment_method")
  mpesaRef        String?         @map("mpesa_ref") 
  initiatedBy     String?         @map("initiated_by")  // admin who initiated
  createdAt       DateTime        @default(now())

  @@unique([memberId, year])
  @@index([memberId])
  @@map("annual_renewals")
}

enum RenewalStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
}

// Notifications log
model Notification {
  id              String          @id @default(cuid())
  memberId        String?         @map("member_id")
  member          Member?         @relation(fields: [memberId], references: [id])
  bereavementCaseId String?       @map("bereavement_case_id")
  bereavementCase  BereavementCase? @relation(fields: [bereavementCaseId], references: [id])
  type            NotificationType
  channel         NotificationChannel // SMS, EMAIL, BOTH
  subject         String?         
  message         String          
  recipientPhone  String?         @map("recipient_phone") 
  recipientEmail  String?         @map("recipient_email") 
  status          NotificationStatus @default(PENDING)
  sentAt          DateTime?       @map("sent_at")
  errorMessage    String?         @map("error_message") 
  createdAt       DateTime        @default(now())

  @@index([memberId])
  @@index([type])
  @@index([status])
  @@map("notifications")
}

enum NotificationType {
  MONTHLY_REMINDER
  BEREAVEMENT_NOTICE
  BEREAVEMENT_REMINDER
  RENEWAL_REMINDER
  REGISTRATION_APPROVAL
  PAYMENT_CONFIRMATION
  ARREARS_WARNING
  SUSPENSION_NOTICE
  GENERAL
}

enum NotificationChannel {
  SMS
  EMAIL
  BOTH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// System settings (configurable by admin)
model Settings {
  id                          String  @id @default(cuid())
  monthlyContributionAmount   Decimal @default(200) @map("monthly_contribution_amount") 
  registrationFee             Decimal @default(200) @map("registration_fee") 
  annualRenewalFee            Decimal @default(200) @map("annual_renewal_fee") 
  joiningFeeNewMember         Decimal @default(2600) @map("joining_fee_new_member") 
  joiningFeeOldMember         Decimal @default(5000) @map("joining_fee_old_member") 
  nuclearBenefitAmount        Decimal @default(100000) @map("nuclear_benefit_amount") 
  parentBenefitAmount         Decimal @default(60000) @map("parent_benefit_amount") 
  nuclearContributionPerMember Decimal @default(300) @map("nuclear_contribution_per_member") 
  parentContributionPerMember Decimal @default(200) @map("parent_contribution_per_member") 
  childCoverageMaxAge         Int     @default(25) @map("child_coverage_max_age")
  waitingPeriodMonths         Int     @default(3) @map("waiting_period_months")
  redAlertThreshold           Int     @default(2) @map("red_alert_threshold")
  suspensionThreshold         Int     @default(3) @map("suspension_threshold")
  suspensionDurationMonths    Int     @default(6) @map("suspension_duration_months")
  removalThreshold            Int     @default(6) @map("removal_threshold")
  maxBurialAttendees          Int     @default(2) @map("max_burial_attendees")
  newChurchMemberYears        Int     @default(2) @map("new_church_member_years")

  @@map("settings")
}
